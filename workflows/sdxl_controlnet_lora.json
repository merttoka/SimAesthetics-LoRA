{
  "_comment": "ControlNet + custom LoRA workflow. For use after training DLA aesthetic LoRA.",
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "",
      "clip": ["1", 1]
    },
    "_meta": { "title": "Negative Prompt" }
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 30,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["40", 0],
      "positive": ["21", 0],
      "negative": ["22", 0],
      "latent_image": ["7", 0]
    }
  },
  "4": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["3", 0],
      "vae": ["1", 2]
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "dlaaesthetic, bioluminescent crystalline ecosystem with dense fractal dendritic branches. Scanning electron microscope aesthetic with false-color enhancement. Match the spatial distribution of detail from the input image exactly. Areas with bright structure get rich detail. Areas that are dark or empty remain flat, untextured.",
      "clip": ["40", 1]
    },
    "_meta": { "title": "Positive Prompt (with LoRA trigger)" }
  },
  "7": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "dla_cn_lora",
      "images": ["4", 0]
    }
  },
  "10": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "input.png"
    },
    "_meta": { "title": "DLA Frame Input" }
  },
  "15": {
    "class_type": "CannyEdgePreprocessor",
    "inputs": {
      "image": ["10", 0],
      "low_threshold": 50,
      "high_threshold": 200,
      "resolution": 1024
    }
  },
  "16": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "control-lora-canny-rank256.safetensors"
    }
  },
  "20": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "strength": 0.8,
      "start_percent": 0.0,
      "end_percent": 1.0,
      "positive": ["6", 0],
      "negative": ["2", 0],
      "control_net": ["16", 0],
      "image": ["15", 0]
    }
  },
  "21": {
    "class_type": "Reroute",
    "inputs": { "input": ["20", 0] },
    "_meta": { "title": "CN Positive" }
  },
  "22": {
    "class_type": "Reroute",
    "inputs": { "input": ["20", 1] },
    "_meta": { "title": "CN Negative" }
  },
  "40": {
    "class_type": "LoraLoader",
    "inputs": {
      "lora_name": "dla_aesthetic_sdxl.safetensors",
      "strength_model": 0.8,
      "strength_clip": 0.8,
      "model": ["1", 0],
      "clip": ["1", 1]
    },
    "_meta": { "title": "DLA Aesthetic LoRA" }
  }
}
