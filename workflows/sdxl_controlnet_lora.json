{
  "_comment": "img2img + ControlNet Canny + LoRA — structure preservation with aesthetic. Use denoise 0.5-0.7.",
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "",
      "clip": ["40", 1]
    },
    "_meta": { "title": "Negative Prompt" }
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 30,
      "cfg": 6.0,
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "denoise": 0.6,
      "model": ["40", 0],
      "positive": ["21", 0],
      "negative": ["22", 0],
      "latent_image": ["5", 0]
    }
  },
  "4": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["3", 0],
      "vae": ["1", 2]
    }
  },
  "5": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["10", 0],
      "vae": ["1", 2]
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "simaesthetic, bioluminescent organic network, physarum slime mold veins pulsing with cyan and amber glow, scanning electron microscope aesthetic, extreme depth of field, dark background",
      "clip": ["40", 1]
    },
    "_meta": { "title": "Positive Prompt (with LoRA trigger)" }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "sim_cn_lora",
      "images": ["4", 0]
    }
  },
  "10": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "input.png"
    },
    "_meta": { "title": "Sim Frame Input" }
  },
  "15": {
    "class_type": "CannyEdgePreprocessor",
    "inputs": {
      "image": ["10", 0],
      "low_threshold": 237,
      "high_threshold": 255,
      "resolution": 1024
    }
  },
  "16": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "control-lora-canny-rank256.safetensors"
    }
  },
  "20": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "strength": 0.8,
      "start_percent": 0.0,
      "end_percent": 1.0,
      "positive": ["6", 0],
      "negative": ["2", 0],
      "control_net": ["16", 0],
      "image": ["15", 0]
    }
  },
  "21": {
    "class_type": "Reroute",
    "inputs": { "input": ["20", 0] },
    "_meta": { "title": "CN Positive" }
  },
  "22": {
    "class_type": "Reroute",
    "inputs": { "input": ["20", 1] },
    "_meta": { "title": "CN Negative" }
  },
  "40": {
    "class_type": "LoraLoader",
    "inputs": {
      "lora_name": "sim_aesthetic_sdxl.safetensors",
      "strength_model": 0.9,
      "strength_clip": 0.9,
      "model": ["1", 0],
      "clip": ["1", 1]
    },
    "_meta": { "title": "SimAesthetic LoRA" }
  }
}
