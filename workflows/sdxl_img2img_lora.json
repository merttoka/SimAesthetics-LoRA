{
  "_comment": "img2img + LoRA — best approach for sim frames. Preserves void regions, adds texture to structure only.",
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "",
      "clip": ["40", 1]
    },
    "_meta": { "title": "Negative Prompt" }
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 30,
      "cfg": 6.0,
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "denoise": 0.6,
      "model": ["40", 0],
      "positive": ["6", 0],
      "negative": ["2", 0],
      "latent_image": ["5", 0]
    }
  },
  "4": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["3", 0],
      "vae": ["1", 2]
    }
  },
  "5": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["10", 0],
      "vae": ["1", 2]
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "simaesthetic, bioluminescent organic network, physarum slime mold veins pulsing with cyan and amber glow, scanning electron microscope aesthetic, extreme depth of field, dark background",
      "clip": ["40", 1]
    },
    "_meta": { "title": "Positive Prompt" }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "sim_img2img_lora",
      "images": ["4", 0]
    }
  },
  "10": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "input.png"
    },
    "_meta": { "title": "Sim Frame Input" }
  },
  "40": {
    "class_type": "LoraLoader",
    "inputs": {
      "lora_name": "sim_aesthetic_sdxl.safetensors",
      "strength_model": 0.9,
      "strength_clip": 0.9,
      "model": ["1", 0],
      "clip": ["1", 1]
    },
    "_meta": { "title": "SimAesthetic LoRA" }
  }
}
