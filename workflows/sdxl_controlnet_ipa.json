{
  "_comment": "Full pipeline: ControlNet (structure from DLA) + IPAdapter (style from prev frame) + prompt. Equivalent to BFL API dual-image workflow.",
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "",
      "clip": ["1", 1]
    },
    "_meta": { "title": "Negative Prompt" }
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 30,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["30", 0],
      "positive": ["21", 0],
      "negative": ["22", 0],
      "latent_image": ["7", 0]
    }
  },
  "4": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["3", 0],
      "vae": ["1", 2]
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "A bioluminescent crystalline ecosystem with dense fractal dendritic branches resembling neural pathways and river deltas. Cool blue-white luminescence pulses through interconnected nodes. Scanning electron microscope aesthetic with false-color enhancement in ice blue and warm amber, extreme depth of field. Match the spatial distribution of detail from the input image exactly. Areas with bright structure get rich detail and texture. Areas that are dark or empty remain as flat, untextured, uniform surfaces with no added detail. Maintain the rendering style and color palette from the style reference.",
      "clip": ["1", 1]
    },
    "_meta": { "title": "Positive Prompt (with style ref suffix)" }
  },
  "7": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 768,
      "height": 768,
      "batch_size": 1
    },
    "_meta": { "title": "768px for VRAM (ControlNet + IPAdapter)" }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "dla_cn_ipa",
      "images": ["4", 0]
    }
  },
  "10": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "input.png"
    },
    "_meta": { "title": "DLA Frame Input (structure source)" }
  },
  "12": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "style_ref.png"
    },
    "_meta": { "title": "Style Reference (prev AI frame)" }
  },
  "15": {
    "class_type": "CannyEdgePreprocessor",
    "inputs": {
      "image": ["10", 0],
      "low_threshold": 50,
      "high_threshold": 200,
      "resolution": 768
    }
  },
  "16": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "control-lora-canny-rank256.safetensors"
    }
  },
  "20": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "strength": 0.8,
      "start_percent": 0.0,
      "end_percent": 1.0,
      "positive": ["6", 0],
      "negative": ["2", 0],
      "control_net": ["16", 0],
      "image": ["15", 0]
    }
  },
  "21": {
    "class_type": "Reroute",
    "inputs": { "input": ["20", 0] },
    "_meta": { "title": "CN Positive" }
  },
  "22": {
    "class_type": "Reroute",
    "inputs": { "input": ["20", 1] },
    "_meta": { "title": "CN Negative" }
  },
  "25": {
    "class_type": "IPAdapterModelLoader",
    "inputs": {
      "ipadapter_file": "ip-adapter-plus_sdxl_vit-h.safetensors"
    }
  },
  "26": {
    "class_type": "CLIPVisionLoader",
    "inputs": {
      "clip_name": "CLIP-ViT-H-14-laion2B-s32B-b79K.safetensors"
    }
  },
  "30": {
    "class_type": "IPAdapterApply",
    "inputs": {
      "weight": 0.5,
      "noise": 0.0,
      "weight_type": "original",
      "start_at": 0.0,
      "end_at": 1.0,
      "model": ["1", 0],
      "ipadapter": ["25", 0],
      "clip_vision": ["26", 0],
      "image": ["12", 0]
    },
    "_meta": { "title": "IPAdapter (style from prev frame)" }
  }
}
