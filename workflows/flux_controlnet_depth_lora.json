{
  "_comment": "FLUX + Depth ControlNet + custom LoRA. Core lifecycle prototype workflow for satellite-to-aesthetic pipeline.",
  "1": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "flux1-dev-fp8.safetensors",
      "weight_dtype": "fp8_e4m3fn"
    },
    "_meta": { "title": "FLUX UNET" }
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "clip_l.safetensors",
      "clip_name2": "t5xxl_fp8_e4m3fn.safetensors",
      "type": "flux"
    },
    "_meta": { "title": "FLUX CLIP" }
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 20,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 0.75,
      "model": ["14", 0],
      "positive": ["14", 1],
      "negative": ["14", 2],
      "latent_image": ["15", 0]
    }
  },
  "4": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["3", 0],
      "vae": ["5", 0]
    }
  },
  "5": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "ae.safetensors"
    },
    "_meta": { "title": "FLUX VAE" }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "simaesthetic, bioluminescent organic structure, dense biological matter",
      "clip": ["2", 0]
    },
    "_meta": { "title": "Positive Prompt" }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "",
      "clip": ["2", 0]
    },
    "_meta": { "title": "Negative Prompt (unused by FLUX)" }
  },
  "8": {
    "class_type": "LoraLoaderModelOnly",
    "inputs": {
      "lora_name": "sim_aesthetic_flux.safetensors",
      "strength_model": 0.8,
      "model": ["1", 0]
    },
    "_meta": { "title": "DLA Aesthetic LoRA" }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "flux_depth_lora",
      "images": ["4", 0]
    }
  },
  "10": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "input.png"
    },
    "_meta": { "title": "Simulation Frame Input" }
  },
  "11": {
    "class_type": "DepthAnythingV2Preprocessor",
    "inputs": {
      "image": ["10", 0],
      "ckpt_name": "depth_anything_v2_vitl.pth",
      "resolution": 1024
    },
    "_meta": { "title": "Depth Preprocessor" }
  },
  "13": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "flux_depth_controlnet.safetensors"
    },
    "_meta": { "title": "FLUX Depth ControlNet" }
  },
  "14": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "strength": 0.7,
      "start_percent": 0.0,
      "end_percent": 1.0,
      "positive": ["6", 0],
      "negative": ["7", 0],
      "control_net": ["13", 0],
      "image": ["11", 0],
      "model": ["8", 0]
    },
    "_meta": { "title": "Apply Depth ControlNet" }
  },
  "15": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    },
    "_meta": { "title": "Latent Image" }
  }
}
